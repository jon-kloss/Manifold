{
  "name": "ficsit-planner-renderer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:wasm": "bash ../scripts/regen-web-wasm.sh build",
    "build:web": "pnpm build:wasm && tsc -b && vite build --mode web",
    "build:web:static": "tsc -b && vite build --mode web",
    "preview": "vite preview",
    "preview:web": "vite preview --outDir dist-web",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:web": "playwright test --config playwright.web.config.ts"
  },
  "dependencies": {
    "@etothepii/satisfactory-file-parser": "^4.1.1",
    "@fontsource/barlow": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/rajdhani": "^5.2.5",
    "@mlc-ai/web-llm": "^0.2.84",
    "@tauri-apps/api": "^2.9.0",
    "@xyflow/react": "^12.8.4",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.4",
    "typescript": "~5.9.2",
    "vite": "^7.1.0",
    "vitest": "^4.1.10"
  }
}
